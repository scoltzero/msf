#!/bin/bash
export PATH="/usr/sbin:/sbin:/usr/bin:/bin:$PATH"

BIN="${TRIM_APPDEST}/msf"
DATA="${TRIM_PKGVAR:-${TRIM_APPDEST}/var}"
PORT="${TRIM_SERVICE_PORT:-7777}"
export MSF_DATA_DIR="${DATA}"

LOG_FILE="${DATA}/msf.log"
PID_FILE="${DATA}/app.pid"
mkdir -p "${DATA}"

CMD="${BIN} serve --config ${DATA} --host 0.0.0.0 --port ${PORT}"

check_process() { kill -0 "$1" 2>/dev/null; }

status_check() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && check_process "${pid}"; then
            return 0
        fi
        rm -f "${PID_FILE}"
    fi
    return 1
}

case "$1" in
start)
    if status_check; then exit 0; fi
    if [ ! -x "${BIN}" ]; then
        echo "$(date) missing binary ${BIN}" >> "${LOG_FILE}"
        [ -n "${TRIM_TEMP_LOGFILE}" ] && echo "missing binary ${BIN}" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi
    bash -c "exec ${CMD}" >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "${PID_FILE}"
    exit 0
    ;;
stop)
    "${BIN}" stop --config "${DATA}" --timeout 20s --force >/dev/null 2>&1
    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && check_process "${pid}"; then
            kill -TERM "${pid}" 2>/dev/null
            c=0
            while check_process "${pid}" && [ $c -lt 10 ]; do sleep 1; c=$((c+1)); done
            check_process "${pid}" && kill -KILL "${pid}" 2>/dev/null
        fi
        rm -f "${PID_FILE}"
    fi
    pkill -9 -x msf 2>/dev/null
    exit 0
    ;;
status)
    if status_check; then exit 0; else exit 3; fi
    ;;
*)
    exit 1
    ;;
esac
